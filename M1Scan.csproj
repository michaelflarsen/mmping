<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>false</UseWindowsForms>
    <RootNamespace>M1Scan</RootNamespace>
    <AssemblyName>M1Scan</AssemblyName>
    <Version>1.0.2</Version>
    <Authors>Michael Larsen</Authors>
    <Description>Advanced Windows Network Utility - Network Scanning, IP Management, ARP/Ping</Description>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ApplicationIcon>app.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.2.2" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Resources\Themes\" />
    <Resource Include="app.ico"/>
    <Resource Include="Resources\ntech-logo.png"/>
  </ItemGroup>

</Project>
